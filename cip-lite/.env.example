# ==========================================
# CLINE TRADING BOT - Environment Variables
# ==========================================
# Copia este archivo a .env y reemplaza los valores
# NUNCA subas el archivo .env real al repositorio

# ==========================================
# API KEYS DE EXCHANGES (CRÍTICO)
# ==========================================
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_SECRET_KEY=tu_secret_key_aqui
BINANCE_TESTNET=true  # true para paper trading, false para real

# Coinbase (si se usa)
COINBASE_API_KEY=tu_api_key_aqui
COINBASE_SECRET_KEY=tu_secret_aqui

# Kraken (si se usa)
KRAKEN_API_KEY=tu_api_key_aqui
KRAKEN_SECRET_KEY=tu_secret_aqui

# ==========================================
# CONFIGURACIÓN DE TRADING
# ==========================================
INITIAL_CAPITAL=10000.0
RISK_PER_TRADE=0.02  # 2% del capital por trade
MAX_POSITION_SIZE=0.1  # 10% máximo del capital en una posición
MAX_DAILY_LOSS=500.0  # Pérdida máxima diaria en USD

# Símbolos a operar (separados por coma)
TRADING_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT

# Intervalos
TRADING_INTERVAL_SECONDS=60
INTELLIGENCE_INTERVAL_MINUTES=60

# ==========================================
# CONFIGURACIÓN DE RIESGO
# ==========================================
MAX_DRAWDOWN_PERCENT=10.0  # Drawdown máximo permitido
VAR_CONFIDENCE_LEVEL=0.95  # Nivel de confianza para VaR
STOP_LOSS_PERCENT=2.0  # Stop loss por defecto
TAKE_PROFIT_PERCENT=3.0  # Take profit por defecto

# ==========================================
# ML / BRAIN CONFIG
# ==========================================
MIN_CONFIDENCE_THRESHOLD=0.5  # Confianza mínima para operar
USE_ONNX_MODEL=true
ONNX_MODEL_PATH=regime_model.onnx

# ==========================================
# LOGGING Y MONITORING
# ==========================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
ENABLE_TELEMETRY=false
TELEMETRY_ENDPOINT=https://tu-endpoint.com/metrics

# ==========================================
# SEGURIDAD
# ==========================================
ADMIN_MODE=true  # Requiere confirmación para operaciones críticas
EMERGENCY_STOP_ENABLED=true
HEALTH_CHECK_INTERVAL=300  # Segundos entre health checks

# ==========================================
# DATA SOURCES
# ==========================================
DATA_SOURCE=ccxt  # ccxt, mt5, synthetic
HISTORICAL_DATA_LIMIT=500  # Número de velas históricas

# ==========================================
# BACKTESTING
# ==========================================
BACKTEST_START_DATE=2024-01-01
BACKTEST_END_DATE=2024-12-31
BACKTEST_INITIAL_CAPITAL=10000.0
BACKTEST_COMMISSION_RATE=0.001  # 0.1% comisión

# ==========================================
# LEGACY CIP Lite Config
# ==========================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=cip-lite-bot/1.0
REDIS_URL=redis://localhost:6379
DUCKDB_PATH=./data/cip_lite.duckdb
ENABLE_ONCHAIN=true
ENABLE_PAPER_TRADING=false
